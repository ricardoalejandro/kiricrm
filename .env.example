NODE_ENV=development
HOST=127.0.0.1
PORT=8080
PUBLIC_URL=http://localhost:8080
KIRI_DEV_API_TOKEN=replace-with-a-random-token-at-least-32-characters
DATABASE_URL=postgresql://kiricrm:kiricrm@localhost:5432/kiricrm?schema=public
REDIS_URL=redis://localhost:6379
META_GRAPH_API_VERSION=v25.0
WA_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-meta-verify-token
WA_WEBHOOK_APP_SECRET=replace-with-meta-app-secret
WA_TOKEN_ENCRYPTION_KEY=replace-with-base64-32-byte-key
WA_SENDING_ENABLED=false
WA_TEMPLATES_ENABLED=false
WA_DEFAULT_DAILY_LIMIT=100
WA_DEFAULT_RATE_LIMIT_PER_SECOND=1
WA_DEV_ACCOUNT_SLUG=dev
WA_DEV_ACCOUNT_NAME=Kiri CRM Dev
JWT_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-characters
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOGIN_ENABLED=true
