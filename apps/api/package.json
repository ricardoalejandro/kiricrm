{
  "name": "@kiricrm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --env-file=../../.env --watch dist/main.js",
    "build": "tsc -p tsconfig.json",
    "db:generate": "node ../../scripts/prisma-with-root-env.cjs generate --schema prisma/schema.prisma",
    "db:push": "node ../../scripts/prisma-with-root-env.cjs db push --schema prisma/schema.prisma",
    "start": "node dist/main.js",
    "start:local": "node --env-file=../../.env dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/helmet": "13.0.2",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-fastify": "11.1.27",
    "@prisma/client": "6.19.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.17.57",
    "prisma": "6.19.0",
    "typescript": "5.9.3"
  }
}
